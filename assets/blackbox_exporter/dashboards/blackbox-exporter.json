{
   "__inputs": [ ],
   "__requires": [ ],
   "annotations": {
      "list": [ ]
   },
   "description": "A dashboard that monitors the Blackbox Exporter. It is created using the [blackbox-exporter-mixin](https://github.com/adinhodovic/blackbox-exporter-mixin) for the [blackbox-exporter](https://github.com/prometheus/blackbox_exporter). The dashboards were generated using [blackbox-exporter-mixin](https://github.com/adinhodovic/blackbox-exporter-mixin). Open issues and create feature requests in the repository.",
   "editable": false,
   "panels": [
      {
         "collapsed": false,
         "gridPos": {
            "h": 1,
            "w": 24,
            "x": 0,
            "y": 0
         },
         "id": 1,
         "title": "Summary",
         "type": "row"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Current up/down status for all probes. Each probe is shown as Up (green) or Down (red). Click a probe to navigate to its detail view.",
         "fieldConfig": {
            "defaults": {
               "links": [
                  {
                     "targetBlank": true,
                     "title": "Go To Probe",
                     "type": "link",
                     "url": "d/blackbox-exporter-j4da/blackbox-exporter?var-instance=${__field.labels.instance}&var-job=${__field.labels.job}"
                  }
               ],
               "mappings": [
                  {
                     "options": {
                        "0": {
                           "color": "red",
                           "text": "Down"
                        },
                        "1": {
                           "color": "green",
                           "text": "Up"
                        }
                     },
                     "type": "value"
                  }
               ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "green",
                        "value": 0
                     }
                  ]
               },
               "unit": "short"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 5,
            "w": 24,
            "x": 0,
            "y": 1
         },
         "id": 2,
         "maxDataPoints": 100,
         "options": {
            "colorMode": "background",
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "showPercentChange": false,
            "text": {
               "titleSize": 18,
               "valueSize": 18
            },
            "textMode": "value_and_name"
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
               },
               "expr": "max by (instance) (\n  probe_success{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n\n  }\n)\n",
               "legendFormat": "{{instance}}"
            }
         ],
         "title": "Status Map",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Total number of probes currently being monitored.",
         "fieldConfig": {
            "defaults": {
               "mappings": [ ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": 0
                     },
                     {
                        "color": "green",
                        "value": 0.001
                     }
                  ]
               },
               "unit": "short"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 4,
            "w": 6,
            "x": 0,
            "y": 6
         },
         "id": 3,
         "options": {
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "showPercentChange": false
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "count(\n  probe_success{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n\n  }\n)\n",
               "instant": false
            }
         ],
         "title": "Probes",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Percentage of probes currently reporting success.",
         "fieldConfig": {
            "defaults": {
               "mappings": [ ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": 0
                     },
                     {
                        "color": "yellow",
                        "value": 0.98999999999999999
                     },
                     {
                        "color": "green",
                        "value": 0.999
                     }
                  ]
               },
               "unit": "percentunit"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 4,
            "w": 6,
            "x": 6,
            "y": 6
         },
         "id": 4,
         "options": {
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "showPercentChange": false
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "(\n  count(\n    probe_success{\n      cluster=\"$cluster\",\njob=~\"$job\"\n\n\n    } == 1\n  )\n  OR vector(0)\n) /\ncount(\n  probe_success{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n\n  }\n)\n",
               "instant": false
            }
         ],
         "title": "Probes Success",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Percentage of HTTP probes using SSL/TLS.",
         "fieldConfig": {
            "defaults": {
               "mappings": [ ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": 0
                     },
                     {
                        "color": "green",
                        "value": 0.999
                     }
                  ]
               },
               "unit": "percentunit"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 4,
            "w": 6,
            "x": 12,
            "y": 6
         },
         "id": 5,
         "options": {
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "showPercentChange": false
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "count(\n  probe_http_ssl{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n\n  } == 1\n) /\ncount(\n  probe_http_version{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n\n  }\n)\n",
               "instant": false
            }
         ],
         "title": "Probes SSL",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Average probe duration across all monitored instances.",
         "fieldConfig": {
            "defaults": {
               "mappings": [ ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "green",
                        "value": 0
                     }
                  ]
               },
               "unit": "s"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 4,
            "w": 6,
            "x": 18,
            "y": 6
         },
         "id": 6,
         "options": {
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "showPercentChange": false
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "avg(\n  probe_duration_seconds{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n\n  }\n)\n",
               "instant": false
            }
         ],
         "title": "Probe Average Duration",
         "type": "stat"
      },
      {
         "collapsed": false,
         "gridPos": {
            "h": 1,
            "w": 24,
            "x": 0,
            "y": 10
         },
         "id": 7,
         "repeat": "instance",
         "title": "$instance",
         "type": "row"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Current probe success rate for the selected instance.",
         "fieldConfig": {
            "defaults": {
               "mappings": [ ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": 0
                     },
                     {
                        "color": "yellow",
                        "value": 0.98999999999999999
                     },
                     {
                        "color": "green",
                        "value": 0.999
                     }
                  ]
               },
               "unit": "percentunit"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 3,
            "w": 3,
            "x": 0,
            "y": 11
         },
         "id": 8,
         "options": {
            "colorMode": "background",
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "reduceOptions": {
               "calcs": [
                  "mean"
               ]
            },
            "showPercentChange": false
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "max by (instance) (\n  probe_success{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n,\ninstance=~\"$instance\"\n\n  }\n)\n",
               "instant": false
            }
         ],
         "title": "Uptime",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Average probe success rate over the last 30 days.",
         "fieldConfig": {
            "defaults": {
               "mappings": [ ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": 0
                     },
                     {
                        "color": "yellow",
                        "value": 0.98999999999999999
                     },
                     {
                        "color": "green",
                        "value": 0.999
                     }
                  ]
               },
               "unit": "percentunit"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 3,
            "w": 3,
            "x": 3,
            "y": 11
         },
         "id": 9,
         "options": {
            "colorMode": "background",
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "reduceOptions": {
               "calcs": [
                  "mean"
