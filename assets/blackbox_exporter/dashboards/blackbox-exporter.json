         "id": 10,
         "options": {
            "colorMode": "background",
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "showPercentChange": false
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "max by (instance) (\n  probe_success{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n,\ninstance=~\"$instance\"\n\n  }\n)\n",
               "instant": true
            }
         ],
         "title": "Probe Success",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Most recent HTTP status code returned by the probe.",
         "fieldConfig": {
            "defaults": {
               "mappings": [ ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "green",
                        "value": 0
                     },
                     {
                        "color": "blue",
                        "value": 300
                     },
                     {
                        "color": "yellow",
                        "value": 400
                     },
                     {
                        "color": "red",
                        "value": 500
                     }
                  ]
               },
               "unit": "short"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 3,
            "w": 3,
            "x": 3,
            "y": 14
         },
         "id": 11,
         "options": {
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "showPercentChange": false
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "max by (instance) (\n  probe_http_status_code{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n,\ninstance=~\"$instance\"\n\n  }\n)\n",
               "instant": true
            }
         ],
         "title": "Latest Response Code",
         "type": "stat"
