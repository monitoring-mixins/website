                  "uid": "$datasource"
               },
               "expr": "avg_over_time(\n  probe_success{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n,\ninstance=~\"$instance\"\n\n  }[30d]\n)\n",
               "instant": false
            }
         ],
         "title": "Uptime 30d",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Whether the most recent probe succeeded.",
         "fieldConfig": {
            "defaults": {
               "mappings": [
                  {
                     "options": {
                        "0": {
                           "color": "red",
                           "text": "No"
                        },
                        "1": {
                           "color": "green",
                           "text": "Yes"
                        }
                     },
                     "type": "value"
                  }
               ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "green",
                        "value": 0
                     }
                  ]
               },
               "unit": "short"
            },
            "overrides": [ ]
