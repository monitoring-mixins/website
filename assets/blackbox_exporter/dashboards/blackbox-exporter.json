            "colorMode": "background",
            "graphMode": "none",
            "percentChangeColorMode": "standard",
            "showPercentChange": false
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "$datasource"
               },
               "expr": "min by (instance) (\n  probe_ssl_earliest_cert_expiry{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n,\ninstance=~\"$instance\"\n\n  } - time()\n)\n",
               "instant": false
            }
         ],
