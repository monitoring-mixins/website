         "gridPos": {
            "h": 3,
            "w": 3,
            "x": 3,
            "y": 17
         },
         "id": 13,
         "options": {
            "graphMode": "area",
            "percentChangeColorMode": "standard",
            "showPercentChange": false,
            "textMode": "name"
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${datasource}"
               },
               "expr": "max by (instance,version) (\n  probe_tls_version_info{\n    cluster=\"$cluster\",\njob=~\"$job\"\n\n,\ninstance=~\"$instance\"\n\n  }\n)\n",
               "instant": true,
               "legendFormat": "{{version}}"
            }
         ],
         "title": "SSL Version",
         "type": "stat"
      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "Time remaining until the SSL certificate expires. Red when below the configured threshold.",
         "fieldConfig": {
            "defaults": {
               "mappings": [ ],
               "thresholds": {
                  "steps": [
                     {
                        "color": "red",
                        "value": 0
                     },
                     {
                        "color": "green",
                        "value": 1814400
                     }
                  ]
               },
               "unit": "dtdurations"
            },
            "overrides": [ ]
         },
         "gridPos": {
            "h": 3,
            "w": 3,
            "x": 0,
            "y": 20
