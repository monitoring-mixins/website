      {
         "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
         },
         "description": "Per-instance overview: uptime, QPS, replica set state and command latency.",
         "fieldConfig": {
            "defaults": {
               "color": {
                  "fixedColor": "#5794f2",
                  "mode": "palette-classic"
               },
               "thresholds": {
                  "mode": "absolute",
                  "steps": [ ]
               }
            },
            "overrides": [
               {
                  "matcher": {
                     "id": "byName",
                     "options": "Uptime"
                  },
                  "properties": [
                     {
                        "id": "unit",
                        "value": "s"
                     }
                  ]
               },
               {
                  "matcher": {
                     "id": "byName",
                     "options": "QPS"
                  },
                  "properties": [
                     {
                        "id": "unit",
                        "value": "ops"
                     }
                  ]
               },
               {
                  "matcher": {
                     "id": "byName",
                     "options": "Latency"
                  },
                  "properties": [
                     {
                        "id": "unit",
                        "value": "µs"
                     }
                  ]
               },
               {
                  "matcher": {
                     "id": "byName",
                     "options": "Replica set"
                  },
                  "properties": [
                     {
                        "id": "mappings",
                        "value": [
                           {
                              "options": {
                                 "0": {
                                    "index": 0,
                                    "text": "STARTUP"
                                 },
                                 "1": {
                                    "index": 1,
                                    "text": "PRIMARY (Healthy)"
                                 },
                                 "10": {
                                    "index": 9,
                                    "text": "REMOVED"
                                 },
                                 "2": {
                                    "index": 2,
                                    "text": "SECONDARY (Healthy)"
                                 },
                                 "3": {
                                    "index": 3,
                                    "text": "RECOVERING"
                                 },
                                 "5": {
                                    "index": 4,
                                    "text": "STARTUP2"
                                 },
                                 "6": {
                                    "index": 5,
                                    "text": "UNKNOWN"
                                 },
                                 "7": {
                                    "index": 6,
                                    "text": "ARBITER"
                                 },
                                 "8": {
                                    "index": 7,
                                    "text": "DOWN"
                                 },
                                 "9": {
                                    "index": 8,
                                    "text": "ROLLBACK"
                                 }
                              },
                              "type": "value"
                           }
                        ]
                     }
                  ]
               }
            ]
         },
         "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 1
         },
         "id": 2,
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${prometheus_datasource}"
               },
               "expr": "max by (instance) (mongodb_instance_uptime_seconds{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\"})",
               "format": "table",
               "instant": true,
               "legendFormat": "{{instance}}",
               "refId": "Uptime"
            },
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${prometheus_datasource}"
               },
               "expr": "sum by (instance) (irate(mongodb_mongod_op_counters_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!=\"command\"}[$__rate_interval]) or irate(mongodb_op_counters_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!=\"command\"}[$__rate_interval]))",
               "format": "table",
               "instant": true,
               "interval": "2m",
               "legendFormat": "{{instance}}",
               "refId": "QPS"
            },
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${prometheus_datasource}"
               },
               "expr": "max by (instance) (mongodb_mongod_replset_my_state{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\"})",
               "format": "table",
               "instant": true,
               "legendFormat": "{{instance}}",
               "refId": "State"
            },
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${prometheus_datasource}"
               },
               "expr": "max by (instance) (irate(mongodb_mongod_op_latencies_latency_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type=\"command\"}[$__rate_interval]) / (irate(mongodb_mongod_op_latencies_ops_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type=\"command\"}[$__rate_interval]) > 0))",
               "format": "table",
               "instant": true,
               "interval": "2m",
               "legendFormat": "{{instance}}",
               "refId": "Latency"
            }
         ],
         "title": "Instances",
         "transformations": [
            {
               "id": "joinByField",
               "options": {
                  "byField": "instance",
                  "mode": "outer"
               }
            },
            {
               "id": "organize",
               "options": {
                  "excludeByName": {
                     "Time": true
                  },
                  "indexByName": {
                     "Value #Latency": 4,
                     "Value #QPS": 2,
                     "Value #State": 3,
                     "Value #Uptime": 1,
                     "instance": 0
                  },
                  "renameByName": {
                     "Value #Latency": "Latency",
                     "Value #QPS": "QPS",
                     "Value #State": "Replica set",
                     "Value #Uptime": "Uptime",
                     "instance": "Instance"
                  }
               }
            }
         ],
         "type": "table"
      },
      {
         "collapsed": false,
