      {
         "datasource": {
            "type": "prometheus",
            "uid": "${prometheus_datasource}"
         },
         "description": "Rate of operations by type.",
         "fieldConfig": {
            "defaults": {
               "color": {
                  "fixedColor": "#5794f2",
                  "mode": "palette-classic"
               },
               "custom": {
                  "fillOpacity": 30,
                  "gradientMode": "opacity",
                  "lineInterpolation": "smooth",
                  "lineWidth": 2,
                  "showPoints": "never"
               },
               "thresholds": {
                  "mode": "absolute",
                  "steps": [ ]
               },
               "unit": "ops"
            }
         },
         "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 10
         },
         "id": 4,
         "options": {
            "legend": {
               "calcs": [ ],
               "displayMode": "list"
            },
            "tooltip": {
               "mode": "multi",
               "sort": "desc"
            }
         },
         "pluginVersion": "v11.4.0",
         "targets": [
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${prometheus_datasource}"
               },
               "expr": "avg by (job,mongodb_cluster,service_name,instance, type) (\n  irate(mongodb_mongod_op_counters_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!=\"command\"}[$__rate_interval])\n  or irate(mongodb_op_counters_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!=\"command\"}[$__rate_interval])\n)\nand\navg by (job,mongodb_cluster,service_name,instance, type) (\n  increase(mongodb_mongod_op_counters_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!=\"command\"}[$__range])\n  or increase(mongodb_op_counters_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!=\"command\"}[$__range])\n) > 0\n",
               "format": "time_series",
               "instant": false,
               "interval": "2m",
               "legendFormat": "{{instance}} - {{type}}",
               "refId": "Operations by type"
            },
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${prometheus_datasource}"
               },
               "expr": "avg by (job,mongodb_cluster,service_name,instance, type) (\n  irate(mongodb_mongod_op_counters_repl_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!~\"(command|query|getmore)\"}[$__rate_interval])\n  or irate(mongodb_mongos_op_counters_repl_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!~\"(command|query|getmore)\"}[$__rate_interval])\n)\nand\navg by (job,mongodb_cluster,service_name,instance, type) (\n  increase(mongodb_mongod_op_counters_repl_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!~\"(command|query|getmore)\"}[$__range])\n  or increase(mongodb_mongos_op_counters_repl_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\", type!~\"(command|query|getmore)\"}[$__range])\n) > 0\n",
               "format": "time_series",
               "instant": false,
               "interval": "2m",
               "legendFormat": "{{instance}} - {{type}}",
               "refId": "Replication operations"
            },
            {
               "datasource": {
                  "type": "prometheus",
                  "uid": "${prometheus_datasource}"
               },
               "expr": "avg by (job,mongodb_cluster,service_name,instance) (\n  irate(mongodb_mongod_metrics_ttl_deleted_documents_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\"}[$__rate_interval])\n  or irate(mongodb_mongos_metrics_ttl_deleted_documents_total{job=~\"$job\",mongodb_cluster=~\"$mongodb_cluster\",service_name=~\"$service_name\"}[$__rate_interval])\n)\n",
               "format": "time_series",
               "instant": false,
               "interval": "2m",
               "legendFormat": "{{instance}} - TTL deleted",
               "refId": "Documents deleted by TTL"
            }
         ],
         "title": "Operations by type",
         "type": "timeseries"
      },
